  4. Nginx — dua server block terpisah

  Backend (aytsalessys.web.id → proxy ke Go, semua path karena route Go sudah punya prefix /api sendiri):
  sudo tee /etc/nginx/sites-available/aytsalessys > /dev/null <<'EOF'
  server {
      listen 80;
      server_name aytsalessys.web.id;
      
      location / {
          proxy_pass http://127.0.0.1:8080;
          proxy_http_version 1.1;
          proxy_set_header Host $host;
          proxy_set_header X-Real-IP $remote_addr;
          proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
          proxy_read_timeout 60s;
